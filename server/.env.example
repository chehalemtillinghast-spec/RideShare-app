DATABASE_URL=postgres://user:password@localhost:5432/rideshare
JWT_SECRET=change_this_to_a_long_random_string
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Generate with: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Forgot-password emails, via Resend (resend.com). Free tier: 3,000/month.
# Sign up, copy your API key. RESEND_FROM can stay as the default sandbox
# sender (onboarding@resend.dev) unless you've verified your own domain.
RESEND_API_KEY=
RESEND_FROM=Town Rides <onboarding@resend.dev>
