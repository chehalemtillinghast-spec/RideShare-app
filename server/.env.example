DATABASE_URL=postgres://user:password@localhost:5432/rideshare
JWT_SECRET=change_this_to_a_long_random_string
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Generate with: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Forgot-password emails. Using Gmail SMTP: enable 2-Step Verification on the
# sending account, then generate a 16-char "app password" and use it below
# (not your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
